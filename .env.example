# Finance Stack — environment variables
# Copy to .env and customize

# Server port
PORT=8000

# Quote backend: mock | yahoo | alpaca
FINANCE_QUOTE_BACKEND=mock

# Cache TTL in seconds for yahoo/alpaca backend
QUOTE_CACHE_TTL=30

# Database path
FINANCE_DB_PATH=./data/finance.db

# Require API key auth (true/false)
REQUIRE_AUTH=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Price simulator (mock backend only, set to 0 to disable)
SIMULATE_PRICES=1

# Record equity snapshots periodically to build risk history (seconds; 0 disables)
EQUITY_SNAPSHOT_INTERVAL_SECONDS=15

# ── Alpaca Paper Trading (free at https://alpaca.markets) ────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# Optional: include Alpaca account ping in GET /api/health
HEALTH_CHECK_ALPACA=false

# Allow POST /api/strategies/forward-signals-alpaca and MCP forward_strategy_signals_to_alpaca
SIGNALS_TO_ALPACA=false

# Route /api/place-order to Alpaca and mirror fills into local ledger:
# internal | alpaca_paper
BROKER_EXECUTION_MODE=internal

# ── Risk budget (VaR/CVaR) ───────────────────────────────────
# Enable by setting non-zero fractions of equity (e.g. 0.04 = 4%).
# Budgets require some equity history (>=10 return observations).
RISK_MAX_VAR_95_PCT_OF_EQUITY=0.0
RISK_MAX_CVAR_95_PCT_OF_EQUITY=0.0
